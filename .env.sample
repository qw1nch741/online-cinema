# ---------- App ----------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- PostgreSQL ----------
POSTGRES_USER=cinema_admin
POSTGRES_PASSWORD=cinema_password_2026
POSTGRES_HOST=db
POSTGRES_DB_PORT=5432
POSTGRES_DB=online_cinema_dev

# Optional: direct DB URL (use if your app reads a single URL)
ASYNC_DATABASE_URL=postgresql+asyncpg://cinema_admin:cinema_password_2026@db:5432/online_cinema_dev

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- JWT / Auth ----------
SECRET_KEY_ACCESS=replace_with_long_random_access_secret
SECRET_KEY_REFRESH=replace_with_long_random_refresh_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Email (dev placeholders) ----------
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_USE_TLS=false

# ---------- MinIO (only if used) ----------
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_password_2026

# ---------- Swagger / OpenAPI ----------
# Set to false in production to disable public API documentation
OPENAPI_DOCS_ENABLED=true